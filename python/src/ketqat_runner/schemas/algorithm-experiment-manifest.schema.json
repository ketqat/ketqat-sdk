{
  "$ref": "#/definitions/algorithm-experiment-manifest",
  "definitions": {
    "algorithm-experiment-manifest": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "const": "ALGORITHM"
        },
        "benchmark": {
          "type": "object",
          "properties": {
            "suite": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "suite",
            "version"
          ],
          "additionalProperties": false
        },
        "experiment": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "source": {
          "type": "object",
          "properties": {
            "repository_url": {
              "type": "string",
              "format": "uri"
            },
            "commit_sha": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "sampling": {
          "type": "object",
          "properties": {
            "shots": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "seed": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "shots",
            "seed"
          ],
          "additionalProperties": false
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "environment": {
          "type": "object",
          "properties": {
            "operating_system": {
              "type": "string"
            },
            "architecture": {
              "type": "string"
            },
            "python_version": {
              "type": "string"
            },
            "node_version": {
              "type": "string"
            },
            "packages": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "hardware": {
              "type": "object",
              "additionalProperties": {},
              "default": {}
            }
          },
          "additionalProperties": false
        },
        "algorithm": {
          "type": "object",
          "properties": {
            "family": {
              "type": "string",
              "minLength": 1
            },
            "problem": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "qubit_counts": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  "minItems": 1
                },
                "marked_state": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "qubit_counts"
              ],
              "additionalProperties": false
            },
            "execution": {
              "type": "object",
              "properties": {
                "engine": {
                  "type": "string",
                  "minLength": 1
                },
                "method": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "engine",
                "method"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "family",
            "problem",
            "execution"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema_version",
        "domain",
        "benchmark",
        "experiment",
        "sampling",
        "metrics",
        "algorithm"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
