{
  "$ref": "#/definitions/qec-experiment-manifest",
  "definitions": {
    "qec-experiment-manifest": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "const": "QEC"
        },
        "benchmark": {
          "type": "object",
          "properties": {
            "suite": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "suite",
            "version"
          ],
          "additionalProperties": false
        },
        "experiment": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "source": {
          "type": "object",
          "properties": {
            "repository_url": {
              "type": "string",
              "format": "uri"
            },
            "commit_sha": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "sampling": {
          "type": "object",
          "properties": {
            "shots": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "seed": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "shots",
            "seed"
          ],
          "additionalProperties": false
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "environment": {
          "type": "object",
          "properties": {
            "operating_system": {
              "type": "string"
            },
            "architecture": {
              "type": "string"
            },
            "python_version": {
              "type": "string"
            },
            "node_version": {
              "type": "string"
            },
            "packages": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "hardware": {
              "type": "object",
              "additionalProperties": {},
              "default": {}
            }
          },
          "additionalProperties": false
        },
        "qec": {
          "type": "object",
          "properties": {
            "experiment_type": {
              "type": "string",
              "minLength": 1
            },
            "code": {
              "type": "object",
              "properties": {
                "family": {
                  "type": "string",
                  "minLength": 1
                },
                "distances": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  "minItems": 1
                },
                "rounds": {
                  "anyOf": [
                    {
                      "type": "string",
                      "const": "distance"
                    },
                    {
                      "type": "integer",
                      "exclusiveMinimum": 0
                    }
                  ]
                }
              },
              "required": [
                "family",
                "distances",
                "rounds"
              ],
              "additionalProperties": false
            },
            "noise": {
              "type": "object",
              "properties": {
                "model": {
                  "type": "string",
                  "minLength": 1
                },
                "physical_error_rates": {
                  "type": "array",
                  "items": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "minItems": 1
                }
              },
              "required": [
                "model",
                "physical_error_rates"
              ],
              "additionalProperties": false
            },
            "decoder": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "version": {
                  "type": "string"
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "experiment_type",
            "code",
            "noise",
            "decoder"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema_version",
        "domain",
        "benchmark",
        "experiment",
        "sampling",
        "metrics",
        "qec"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
