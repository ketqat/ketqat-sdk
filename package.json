{
  "name": "ketqat-sdk",
  "version": "0.1.0",
  "description": "TypeScript types, quantum cloud provider catalog, and reference data for KetQat.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ketqat/ketqat-sdk.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
